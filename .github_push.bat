@echo off
:: 文字化けを防ぐため、文字コードをUTF-8に設定します
chcp 65001 > nul

echo ===================================================
echo   GitHub 自動送信（Push）ツール
echo ===================================================
echo.
echo 【現在の状態を確認します】
git status -s
echo.

:: -----------------------------------------------------
:: [STEP 1] コミットメッセージの入力
:: 固定メッセージにすると後で変更履歴が追えなくなるため、
:: 実行のたびに「何を変えたか」を入力させます。
:: 例：「fix: メニュー名のXSS脆弱性を修正」など
:: -----------------------------------------------------
set /p COMMIT_MSG="今回の変更内容（コミットメッセージ）を入力してください: "

:: 万が一何も入力されなかった場合は、処理を中断する安全装置
if "%COMMIT_MSG%"=="" (
    echo [エラー] メッセージが入力されなかったため、処理を中断します。
    pause
    exit /b
)

echo.
echo ===================================================
echo   送信処理を開始します...
echo ===================================================

:: -----------------------------------------------------
:: [STEP 2] 変更されたファイルをすべて送信リストに登録
:: （新しく作ったファイルも、削除したファイルもすべて検知します）
:: -----------------------------------------------------
echo [1/3] 変更されたファイルを集めています... (git add .)
git add .

:: -----------------------------------------------------
:: [STEP 3] 変更内容を確定して歴史に刻む
:: （先ほど入力したメッセージを使ってコミットします）
:: -----------------------------------------------------
echo [2/3] 変更内容を記録しています... (git commit)
git commit -m "%COMMIT_MSG%"

:: -----------------------------------------------------
:: [STEP 4] GitHubのサーバー（金庫）へ実際にデータを送る
:: （origin = GitHubのURL、main = 送信先のブランチ）
:: -----------------------------------------------------
echo [3/3] GitHubへ送信しています... (git push)
git push origin main

echo.
echo ===================================================
echo   送信が完了しました！
echo   ブラウザでGitHubの画面をリロードして確認してください。
echo ===================================================
pause