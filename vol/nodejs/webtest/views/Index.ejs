<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Meshi-Quest</title>

  <link rel="stylesheet" href="/style/styleLogin.css">
  <style>
    /* タイトルを読みやすくする設定 */
    .project-title {
      color: #ffffff; /* 白文字 */
      margin-bottom: 0;
      font-size: 2.8rem;
      font-weight: bold;
      /* 黒い影とフチをつけて文字を浮かせる */
      text-shadow: 
         2px  2px 4px rgba(0,0,0,0.8),
        -1px -1px 0 #000,  
         1px -1px 0 #000,
        -1px  1px 0 #000,
         1px  1px 0 #000;
    }
  
    .subtitle {
      color: #ffffff;
      font-size: 1.1rem;
      margin-top: 10px;
      font-weight: bold;
      /* サブタイトルもフチを付けて読みやすく */
      text-shadow: 1px 1px 3px rgba(0,0,0,1);
      /* 文字の背景に少しだけ暗い色を敷く（必要なら） */
      background-color: rgba(0, 0, 0, 0.3);
      display: inline-block;
      padding: 2px 10px;
      border-radius: 5px;
    }
  </style>
</head>
<body>
  <main>
    <div style="text-align: center; margin-bottom: 30px;">
      <h1 class="project-title">Meshi-Quest</h1>
      <p class="subtitle">〜至高の一皿を探求する、グルメ特化型ログアプリ〜</p>
    </div>
    
    <div class="box12">
      <a href="/storeInfo">店舗一覧ページはこちら</a>
    </div>
    <div class="box12">
      <a href="/login">ログインまたは新規登録</a>
    </div>
  </main>
</body>
</html>