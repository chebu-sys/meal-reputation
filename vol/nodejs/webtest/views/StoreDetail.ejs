<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title><%= locals.store.name %> の評価</title>
    <link rel="stylesheet" href="/style/storeLayout.css">
</head>
<body>
    <div class="container">
        <div class="left-section">
            <div class="title-wrapper">
                <h1><%= locals.store.name %> の詳細情報</h1>
                
                <% 
                    const avgScore = locals.store.average_score ? parseFloat(locals.store.average_score).toFixed(1) : '評価なし';
                    const score = locals.store.average_score ? parseFloat(locals.store.average_score) : 0;
                    const fullStarsCount = Math.floor(score);
                    const hasHalfStar = (score - fullStarsCount) >= 0.5;
                    const emptyStarsCount = 5 - fullStarsCount - (hasHalfStar ? 1 : 0);
                    let starsHtml = '';
                    for (let i = 0; i < fullStarsCount; i++) {
                        starsHtml += '<span class="star-full">★</span>';
                    }
                    if (hasHalfStar) {
                        starsHtml += '<span class="star-half-container"></span>';
                    }
                    for (let i = 0; i < emptyStarsCount; i++) {
                        starsHtml += '<span class="star-empty">★</span>';
                    }
                %>
                <% if (locals.store.average_score) { %>
                    <span class="average-score" title="<%= avgScore %>点">
                        <span class="star-rating"><%- starsHtml %></span>
                        <span class="score-value">(<%= avgScore %>)</span>
                    </span>
                <% } else { %>
                    <span style="font-size: 1em; color: #666; margin-left: 10px;">(評価なし)</span>
                <% } %>
            </div>

            <p>
                <strong>住所:</strong> <%= locals.store.address %> 
                <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(locals.store.name + ' ' + locals.store.address) %>" 
                    target="_blank" 
                    style="display: inline-block; margin-top: 10px; color: #1a73e8; text-decoration: none; font-size: 0.9em; font-weight: bold; background: #e8f0fe; padding: 8px 16px; border-radius: 8px; border: 1px solid #d2e3fc;">
                    📍 Googleマップで検索する
                 </a>
                 <small style="display: block; color: #666; margin-top: 8px; font-size: 0.8em; line-height: 1.4;">
                     ※店名と住所から検索します。位置が異なる場合は、マップ上で修正して再検索してください。
                 </small>
            </p>
            <p><strong>電話番号:</strong> <%= locals.store.phone_number %></p>
            <p><strong>説明:</strong> <%= locals.store.description %></p>
            
            <% if (locals.store.image_url) { %>
                <% 
                    let aspectRatioPadding = '56.25%';
                    if (locals.store.image_width && locals.store.image_height && locals.store.image_width > 0) {
                        aspectRatioPadding = ((locals.store.image_height / locals.store.image_width) * 100).toFixed(2) + '%';
                    }
                %>
                <div class="store-image-wrapper" style="max-width: 600px;">
                    <div class="store-image-aspect-ratio" style="--aspect-ratio: <%= aspectRatioPadding %>;">
                        <img src="<%= locals.store.image_url %>" alt="<%= locals.store.name %>の画像">
                    </div>
                </div>
            <% } %>

            <hr>
            
            <% if (locals.isLoggedIn) { %>
                <% if (locals.existingRating) { %>
                    <h2><%= locals.store.name %> の評価を編集する</h2>
                    <p style="color: blue; font-size: small;">(現在の評価は登録済みです。内容を変更して「評価を更新する」を押してください。)</p>
                <% } else { %>
                    <h2><%= locals.store.name %> を評価する</h2>
                <% } %>

                <p>ようこそ、<%= userId %> さん。</p>
                
                <form action="/storeInfo/<%= locals.store.store_id %>/review" method="POST" enctype="multipart/form-data">
                    <% if (locals.existingRating) { %>
                        <input type="hidden" name="rating_id" value="<%= existingRating.rating_id %>">
                    <% } %>
                    <h3>評価とコメントの入力</h3>
                    <label for="rating">★評価:</label>
                    <select id="rating" name="rating" required>
                        <option value="">選択してください</option>
                        <% const currentScore = locals.existingRating ? existingRating.score : 0; %>
                        <option value="5" <%= currentScore === 5 ? 'selected' : '' %>>★★★★★</option>
                        <option value="4" <%= currentScore === 4 ? 'selected' : '' %>>★★★★</option>
                        <option value="3" <%= currentScore === 3 ? 'selected' : '' %>>★★★</option>
                        <option value="2" <%= currentScore === 2 ? 'selected' : '' %>>★★</option>
                        <option value="1" <%= currentScore === 1 ? 'selected' : '' %>>★</option>
                    </select>
                    <br><br>
                    <label for="comment">ユーザーコメント:</label>
                    <textarea id="comment" name="comment" rows="4" cols="50" placeholder="コメントを入力してください" required><%= locals.existingRating ? existingRating.comment : '' %></textarea>
                    <br><br>
                    <div style="margin-top: 15px;">
                        <label for="review_image">📸 写真を追加 (任意):</label><br>
                        <input type="file" id="review_image" name="review_image" accept="image/*" onchange="previewImage(this);">
                        <div id="image_preview_container" style="display:none; margin-top:10px;">
                            <img id="image_preview" src="" style="max-width:200px; border-radius:8px; border: 1px solid #ddd;">
                        </div>
                    </div>
                    <button type="submit"><%= locals.existingRating ? '評価を更新する' : '評価を投稿する' %></button>
                </form>
            <% } else { %>
                <h2><%= locals.store.name %> の評価</h2>
                <div class="review-form" style="padding: 20px; border: 1px dashed #ccc; text-align: center; border-radius: 8px;">
                    <p>評価を投稿するには<br><a href="/login" style="color: #ff7f50; font-weight: bold; text-decoration: underline;">ログイン</a>が必要です。</p>
                </div>
            <% } %>
            
            <button type="button" onclick="location.href='/storeInfo'" style="margin-top: 20px;">一覧へ戻る</button>
        </div>

        <div class="right-section">
            <h2>メニュー一覧</h2>
            <% if (menus && menus.length > 0) { %>
                <table class="menu-table">
                    <thead>
                        <tr>
                            <th>メニュー名</th>
                            <th>価格 (円)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% menus.forEach(menu => { %>
                            <tr>
                                <td><%= menu.menu_name %></td>
                                <td><%= menu.price ? menu.price.toLocaleString() : '---' %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>この店舗のメニューは登録されていません。</p>
            <% } %>

            <hr>

            <h2 id="reviews">口コミ評価 (<%= ratings.length %>件)</h2>
            <div class="sort-buttons">
                <button onclick="changeSort('newest')" class="<%= sortBy === 'newest' ? 'active' : '' %>">新規登録順</button>
                <button onclick="changeSort('score')" class="<%= sortBy === 'score' ? 'active' : '' %>">★評価順</button>
            </div>

            <ul class="review-list">
                <% if (ratings && ratings.length > 0) { %>
                    <% ratings.forEach(rating => { %>
                        <% 
                            const isMyPost = locals.isLoggedIn && rating.user_id === userId;
                            const myPostStyle = isMyPost ? 'background-color: #fff9db; border: 2px solid #fab005;' : '';
                        %>
                        <li class="review-item" id="review-<%= rating.rating_id %>" style="<%= myPostStyle %>">
                            <div class="review-header">
                                <div>
                                    <span style="font-size: small; color: #666;">
                                        ユーザー: <%= rating.user_id %>
                                        <% if (isMyPost) { %>
                                            <span style="color: #e67e22; font-weight: bold; margin-left: 5px;">[あなたの投稿]</span>
                                        <% } %>
                                    </span>
                                    <span class="review-score"><%='★'.repeat(rating.score)%></span>
                                </div>
                                <span style="font-size: x-small; color: #999;">
                                    <%= rating.updated_at ? new Date(rating.updated_at).toLocaleDateString('ja-JP') : new Date(rating.created_at).toLocaleDateString('ja-JP') %>
                                </span>
                            </div>
                            <p class="review-comment"><%= rating.comment %></p>

                            <% if (rating.review_image) { %>
                                <div class="review-post-image" style="margin-top: 10px;">
                                    <img src="<%= rating.review_image %>" alt="口コミ写真" style="max-width: 100%; max-height: 300px; border-radius: 8px;">
                                </div>
                            <% } %>
                            
                            <div class="review-actions">
                                <% if (rating.likeCount > 0) { %>
                                    <span class="like-count" style="margin-right: 15px; font-size: small; color: #555;">
                                        ❤️ <%= rating.likeCount %> 件
                                    </span>
                                <% } %>

                                <% if (locals.isLoggedIn) { %>
                                    <% if (rating.user_id !== userId) { %>
                                        <form action="/storeInfo/review/<%= rating.rating_id %>/like" method="POST" style="display: inline;">
                                            <input type="hidden" name="action" value="<%= rating.isLiked ? 'remove' : 'add' %>">
                                            <button type="submit" class="like-button <%= rating.isLiked ? 'liked' : '' %>">
                                                <%= rating.isLiked ? '❤️ いいね済み' : '♡ いいね!' %>
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <span style="font-size: small; color: #999;">(自分の投稿にはいいねできません)</span>
                                    <% } %>
                                <% } %>
                            </div>
                        </li>
                    <% }); %>
                <% } else { %>
                    <p style="padding: 20px;">まだ口コミ評価はありません。</p>
                <% } %>
            </ul>
        </div>
    </div>

    <script>
        function changeSort(sortType) {
            const url = new URL(window.location);
            if (sortType === 'newest') {
                url.searchParams.delete('sort');
            } else {
                url.searchParams.set('sort', sortType);
            }
            window.location.href = url.toString();
        }

        function previewImage(input) {
            const container = document.getElementById('image_preview_container');
            const preview = document.getElementById('image_preview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    container.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                container.style.display = 'none';
            }
        }
    </script>
</body>
</html>