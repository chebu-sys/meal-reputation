<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>ユーザー情報</title>
    <link rel="stylesheet" href="/style/userinfo.css">
</head>

<body class="min-h-screen-center">
    
<% if (registFrag === 1) { %>

    <% 
        // 登録・編集フォームのロジック (元のコードを維持) [cite: 72-80]
        const dbGenderFlag = (typeof genderFlag === 'undefined') ? null : genderFlag;
        
        let selectedGenderValue = "";
        if (dbGenderFlag == 1) {
            selectedGenderValue = "1"; // 男性
        } else if (dbGenderFlag == 0) {
            selectedGenderValue = "2"; // 女性
        } else {
            selectedGenderValue = "";
        }

        const currentRegion = (typeof region === 'undefined') ? null : region;
        let initialOtherValue = "";
        const foodsArray = Array.isArray(favorite_food) ? favorite_food : [];
        const otherFoodWithDetail = foodsArray.find(food => typeof food === 'string' && food.startsWith('その他:'));
        if (otherFoodWithDetail) {
            initialOtherValue = otherFoodWithDetail.substring('その他:'.length);
        }
        const isOtherChecked = foodsArray.includes('その他') || !!otherFoodWithDetail;
    %>

    <div class="form-container"> 
        <h2 class="form-title">
            ユーザー情報 <%= editFrag ? '編集' : '登録' %>フォーム
        </h2>
    
        <form id="user-info-form" action="<%= editFrag ? '/login/userinfo/update' : '/login/userinfo/register' %>" method="POST" enctype="multipart/form-data">
            <input type="hidden" id="favorite-food-output" name="favorite_food">
            
            <div class="form-img-section">
                <% if (profile_image) { %>
                    <img id="profile-preview" src="<%= profile_image %>?t=<%= Date.now() %>" class="profile-img-md">
                <% } else { %>
                    <div id="profile-preview-default" class="profile-img-default-md">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon-lg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </div>
                    <img id="profile-preview" src="#" alt="プレビュー" class="hidden profile-img-md">
                <% } %>
                <label class="img-change-label">
                    <span class="btn-img-change">画像を変更</span>
                    <input type="file" id="profile-image-input" name="profile_image" class="hidden">
                </label>
            </div>
    
            <div class="form-fields-container">
                <div class="form-field-row">
                    <label class="field-label required-label">ニックネーム：</label>
                    <div class="field-input-area">
                         <input type="text" name="nickname" value="<%= nickname || '' %>" class="input-text">
                    </div>
                </div>
    
                <div class="form-field-row">
                    <label class="field-label required-label">性別：</label>
                    <div class="field-input-area">
                         <select name="gender" class="input-select">
                            <option value="" <%= (selectedGenderValue === "") ? 'selected' : '' %>>-- 選択してください --</option>
                            <option value="1" <%= (selectedGenderValue === "1") ? 'selected' : '' %>>男性</option>
                            <option value="2" <%= (selectedGenderValue === "2") ? 'selected' : '' %>>女性</option>
                        </select>
                    </div>
                </div>
    
                <div class="form-field-row">
                    <label class="field-label required-label">地域：</label>
                    <div class="field-input-area">
                        <select name="region" class="input-select">
                          <option value="" <%= (currentRegion === null) ? 'selected' : '' %>>-- 選択してください --</option>
                           <% prefectures.forEach(pref => { %>
                                 <option value="<%= pref %>" <%= (currentRegion === pref) ? 'selected' : '' %>><%= pref %></option>
                           <% }); %>
                        </select>
                    </div>
                </div>
    
                <div class="form-field-row food-field-row"> 
                    <label class="field-label">好きなグルメ (Max 3)：</label>
                    <div class="field-input-area food-options-grid"> 
                        <% ['和食', '洋食', '中華料理', 'アジア', 'カフェ', 'バー'].forEach(food => { %>
                             <label class="checkbox-label">
                                 <input type="checkbox" name="favorite_food_original" value="<%= food %>" <%= (foodsArray.includes(food)) ? 'checked' : '' %> class="input-checkbox">
                                 <span class="ml-2-text"><%= food %></span>
                             </label>
                        <% }); %>
                        <label class="checkbox-label">
                             <input type="checkbox" id="other-food-checkbox" name="favorite_food_original" value="その他" <%= isOtherChecked ? 'checked' : '' %> class="input-checkbox">
                             <span class="ml-2-text">その他</span>
                        </label>
                        <div id="other-food-container" class="other-food-container" data-initial-value="<%= initialOtherValue %>" style="display: <%= isOtherChecked ? 'block' : 'none' %>;">
                             <input type="text" id="other-food-input" placeholder="詳細を入力してください（任意）" value="<%= initialOtherValue %>" class="input-text">
                        </div>
                    </div>
                </div>
                
                <div class="form-field-row">
                    <label class="field-label">自己紹介：</label>
                    <div class="field-input-area">
                        <textarea name="bio" rows="5" class="input-textarea"><%= bio || '' %></textarea>
                    </div>
                </div>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn-primary">
                     <%= editFrag ? '更新する' : '登録する' %>
                </button>
                <a href="/login/userinfo" class="btn-link">
                    キャンセル
                </a>
            </div>
        </form>
    </div>
    
    <script src="/scripts/userinfo.js"></script>
<% } else { %>
    
    <% 
        // 閲覧ページのロジック [cite: 107-117]
        const userIdSafe = locals.userid || '';
        const nicknameSafe = locals.nickname || '';
        
        let genderDisplay = '未設定';
        if (typeof locals.gender !== 'undefined' && locals.gender !== null) {
            if (locals.gender == 1 || locals.gender == '男性') {
                genderDisplay = '男性';
            } else if (locals.gender == 0 || locals.gender == 2 || locals.gender == '女性') { 
                genderDisplay = '女性';
            }
        }
        const genderSafe = genderDisplay;
        const regionSafe = (locals.region === null || locals.region === '') ? '未設定' : locals.region;
        const bioSafe = locals.bio || '自己紹介がまだ登録されていません。編集画面から登録してください。';
        const profileImageSafe = locals.profile_image || null;
        
        const foodsToShow = Array.isArray(locals.favorite_food) 
            ? locals.favorite_food.map(food => {
                if (typeof food === 'string' && food.startsWith('その他:')) {
                    const customText = food.substring('その他:'.length);
                    return customText.trim() ? `その他（${customText}）` : 'その他';
                }
                return food;
            })
            : [];
        const foodsDisplay = foodsToShow.length > 0 ? foodsToShow.join('<br>') : '未設定'; 
        const lastLoginDateSafe = locals.last_login_date || '不明';

        // ★★★ いいね数・レビュー統計変数を取得 ★★★
        const totalLikesReceivedSafe = locals.totalLikesReceived || 0;
        const totalReviewsSafe = locals.totalReviews || 0;
        const averageScoreSafe = locals.averageScore || "0.0";
    %>

    <div class="user-container">
        <div class="user-header">
            <h1 class="user-name">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon-lg-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <%= nicknameSafe || userIdSafe %>
            </h1>
            <a href="/login/userinfo/edit" class="btn-edit">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon-sm-inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                編集する
            </a>
        </div>

        <div class="user-grid">
            <div class="user-sidebar">
                <% if (profileImageSafe) { %>
                    <img src="<%= profileImageSafe %>?t=<%= Date.now() %>" class="profile-img-lg">
                <% } else { %>
                    <div class="profile-img-default-lg">No Image</div>
                <% } %>
                
                <div class="user-info-detail">
                    <p class="user-id-text">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon-sm" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        ユーザーID: <span class="user-id-value"><%= userIdSafe %></span>
                    </p>
                    <div class="info-separator">
                        <p class="info-gender">
                            <span class="mr-2-text"><%= genderSafe === '男性' ? '🧑' : genderSafe === '女性' ? '👩' : '👤' %></span>
                            性別: <span class="font-bold-text"><%= genderSafe %></span>
                        </p>
                    </div>
                    <div class="info-separator">
                        <p class="info-location">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon-md" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            地域: <span class="font-bold-text"><%= regionSafe %></span>
                        </p>
                    </div>
                    <div class="info-food-section">
                        <p class="info-food-title">
                            <span class="mr-2-text">🍽️</span>
                            好きなグルメ:
                        </p>
                        <div class="info-food-content">
                            <%- foodsDisplay %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="user-main-content">
                <div class="stat-box">
                    <h3 class="stat-box-title">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon-md-stat" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                        レビュー統計情報
                    </h3>
                    <div class="stat-grid">
                        <div><p class="stat-number"><%= totalReviewsSafe %></p><p class="stat-label">投稿レビュー数</p></div>
                        <div><p class="stat-number"><%= totalLikesReceivedSafe %></p><p class="stat-label">もらった「いいね」</p></div>
                        <div><p class="stat-number"><%= averageScoreSafe %></p><p class="stat-label">平均評価点</p></div>
                    </div>
                </div>

                <div class="bio-box">
                    <h3 class="bio-box-title">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon-md" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18s-3.332.477-4.5 1.253" />
                        </svg>
                        自己紹介
                    </h3>
                    <p class="bio-content">
                        <%= bioSafe %>
                    </p>
                </div>
  
                <div class="activity-box">
                    <h3 class="activity-box-title">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon-md-activity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        アクティビティ履歴
                    </h3>
                    <div class="activity-detail">
                        <p>
                            最終ログイン日: 
                            <span class="activity-date"><%= lastLoginDateSafe %></span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="user-actions-footer">
            <a href="/storeInfo" class="btn-secondary">戻る</a>
            <button id="delete-account-button" class="btn-delete-account">アカウントを削除する</button>
        </div>
    </div>
    
    <script src="/scripts/userinfo.js"></script>
<% } %>

</body>
</html>