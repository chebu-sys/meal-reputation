<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ログイン | Meshi-Quest</title>
  <link rel="stylesheet" href="/style/styleLogin.css" />
  <style>
    /* デザイン設定はバックアップのまま一切変えていません */
    .input-container {
      position: relative;
      display: flex;
      align-items: center;
      width: 100%;
    }
    .input-container input {
      flex: 1;
    }
    .toggle-password {
      position: absolute;
      right: 10px;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1.2rem;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  
    .project-title {
      color: white;
      margin-bottom: 0;
      font-size: 2.5rem;
      font-weight: bold;
      text-shadow: 2px 2px 3px rgba(0,0,0,0.8), -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, -1px 1px 0 #000;
    }
  
    .subtitle {
      color: white;
      font-size: 1rem;
      margin-top: 5px;
      font-weight: bold;
      text-shadow: 1px 1px 4px rgba(0,0,0,1);
      background-color: rgba(0, 0, 0, 0.3);
      display: inline-block;
      padding: 2px 12px;
      border-radius: 5px;
    }

    .login-box {
        background: rgba(255, 255, 255, 0.25) !important;
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        border-radius: 20px !important;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3) !important;
        color: white !important;
        padding: 30px;
    }

    .login-box h2 {
        color: white !important;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.8) !important;
        margin-bottom: 20px;
    }

    .login-box input[type="text"], 
    .login-box input[type="password"] {
        background: rgba(0, 0, 0, 0.2) !important;
        border: 1px solid rgba(255, 255, 255, 0.4) !important;
        color: white !important;
        border-radius: 8px !important;
        padding: 12px !important;
        font-weight: bold;
    }

    .login-box input[type="submit"] {
        background-color: #ff7f50 !important;
        border: none !important;
        color: white !important;
        font-weight: bold !important;
        font-size: 1.1rem;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        cursor: pointer !important;
        margin-top: 15px;
    }

    .login-box span, .login-box a {
        color: white !important;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8) !important;
        text-decoration: none;
    }
  </style>
</head>
<body>
  <main>
      <div style="text-align: center; margin-bottom: 20px;">
        <h1 class="project-title">Meshi-Quest</h1>
        <p class="subtitle">〜至高の一皿を探求する、グルメ特化型ログアプリ〜</p>
      </div>

    <div class="login-box">
      <% if (isLoggedIn == 1) { %>
          <h2>ユーザーログイン</h2>
            <form action="/home" method="POST" class="form">
              <input type="text" name="username" placeholder="ユーザー名" required>
              <div class="input-container" style="margin-top: 10px;">
                <input type="password" name="password" id="login_password" placeholder="パスワード" required>
                <button type="button" class="toggle-password" onclick="togglePasswordVisibility('login_password', this)">👁️</button>
              </div>
              <input type="submit" value="<%= LogInfo %>">
            </form>
            <div style="margin-top: 20px;">
                <span style="font-size: 14px;">Meshi-Quest への登録がまだの方：</span><br>
                <button type="button" onclick="location.href='/regi'" style="margin-top: 10px;">新規探求者（ユーザー）登録</button>
            </div>
            <div style="margin-top: 15px;">
              <a href="/">TOPへ戻る</a>
            </div>
        <% } else { %>
          <h2>ログイン中</h2>
          
          <div style="margin-bottom: 10px;">
            <button type="button" onclick="location.href='/login/userinfo'" style="padding: 0.5em 1em; margin: 10px auto; width: 100%; color: #ff7f50; background: #c6e4ff; border-bottom: solid 6px #aac5de; border-radius: 9px; font-weight: bold; cursor: pointer; border-top:none; border-left:none; border-right:none; display: block;">ユーザー画面へ</button>
          </div>
          
          <div style="margin-bottom: 20px;">
            <button type="button" onclick="location.href='/storeInfo'" style="padding: 0.5em 1em; margin: 10px auto; width: 100%; color: #ff7f50; background: #c6e4ff; border-bottom: solid 6px #aac5de; border-radius: 9px; font-weight: bold; cursor: pointer; border-top:none; border-left:none; border-right:none; display: block;">店舗一覧ページはこちら</button>
          </div>

          <form action="/logout" method="GET" class="form">
            <input type="submit" value="<%= LogInfo %>">
          </form>
        <% } %>
      </div>
    </main>

    <script>
      function togglePasswordVisibility(inputId, button) {
        const input = document.getElementById(inputId);
        if (input.type === 'password') {
          input.type = 'text';
          button.textContent = '🙈';
        } else {
          input.type = 'password';
          button.textContent = '👁️';
        }
      }
    </script>
</body>
</html>