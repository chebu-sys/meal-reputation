<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>パスワード変更</title>
    
    <%# 新しい専用CSSを読み込む %>
    <link rel="stylesheet" href="/stylesheets/password_change.css">
    
</head>
<body>
    <header class="header-container">
        <a href="/dashboard" class="header-link">ダッシュボードへ戻る</a>
        <a href="/Clogout" class="header-link">ログアウト</a>
    </header>
    
    <div class="main-content-wrapper">
        <h1>パスワード変更</h1>
        <p>パスワードを変更します。</p>
        
        <% if (typeof message !== 'undefined' && message) { %>
            <%# インラインスタイルをCSSで定義したクラスに置き換え %>
            <p class="error-message"><%= message %></p>
        <% } %>

        <form method="POST" action="/password-change">
            
            <%# 1. 現在のパスワード入力フィールド + アイコン %>
            <div>
                <label for="old_password">現在のパスワード：</label>
                <div class="input-container">
                    <input 
                        type="password" 
                        id="old_password" 
                        name="old_password" 
                        value="<%= typeof oldData !== 'undefined' && oldData.old_password ? oldData.old_password : '' %>"
                        required
                    >
                    <button type="button" class="toggle-password" onclick="togglePasswordVisibility('old_password', this)">👁️</button>
                </div>
            </div>
            
            <%# HRタグのインラインスタイルを削除 %>
            <hr>

            <%# 2. 新しいパスワード入力フィールド + アイコン %>
            <div>
                <label for="new_password">新しいパスワード：</label>
                <div class="input-container">
                    <input 
                        type="password" 
                        id="new_password" 
                        name="new_password" 
                        pattern="^(?=.*[a-zA-Z])(?=.*[0-9])(?=.*[!@#$%^&*()_+\-=\[\]{};':\\|,.<>\/?]).{8,20}$"
                        title="パスワードは8文字以上20文字以内の半角英数字と特殊文字を含めてください。"
                        required
                    >
                    <button type="button" class="toggle-password" onclick="togglePasswordVisibility('new_password', this)">👁️</button>
                </div>
                <%# インラインスタイルをCSSで定義したクラスに置き換え %>
                <p class="password-hint">※8〜20文字の半角英数字と特殊文字を含めてください。</p>
            </div>

            <%# 3. 新しいパスワード（確認用）入力フィールド + アイコン %>
            <div>
                <label for="confirm_password">新しいパスワード（確認用）：</label>
                <div class="input-container">
                    <input type="password" id="confirm_password" name="confirm_password" required>
                    <button type="button" class="toggle-password" onclick="togglePasswordVisibility('confirm_password', this)">👁️</button>
                </div>
            </div>

            <div>
                <button type="submit">パスワードを変更</button>
            </div>
        </form>
    </div>
    
    <%# 既存のJSファイルを再利用 %>
    <script src="/javascripts/login.js"></script>
</body>
</html>